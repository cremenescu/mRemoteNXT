/* Help window */
"Help.WindowTitle" = "Pomoc mRemoteNXT";
"Help.Tagline" = "Natywny klient zdalnych połączeń wieloprotokołowych dla macOS";
"Help.WhatIs.Title" = "Czym jest mRemoteNXT?";
"Help.WhatIs.Body" = "Menedżer zdalnych połączeń z kartami dla macOS, który importuje plik confCons.xml z mRemoteNG bez żadnych zmian — wraz z zaszyfrowanymi hasłami, strukturą folderów, dziedziczeniem atrybutów i panelami. Obsługuje sesje SSH, Telnet, SFTP, RDP oraz HTTP/HTTPS bezpośrednio w kartach, dzięki czemu nie potrzebujesz osobnego terminala ani klienta RDP.";
"Help.GettingStarted.Title" = "Pierwsze kroki";
"Help.GettingStarted.Body" = "Przy pierwszym uruchomieniu aplikacja jest pusta. Użyj Plik > Nowa konfiguracja... (Cmd+N), aby utworzyć nowy plik confCons.xml, lub Plik > Otwórz confCons.xml... (Cmd+O), aby załadować istniejący (własny lub wyeksportowany z mRemoteNG w systemie Windows). Przy kolejnym uruchomieniu aplikacja automatycznie otworzy ten sam plik. Użyj Plik > Zamknij konfigurację (Cmd+Shift+W), aby wyczyścić obszar roboczy.";
"Help.Connecting.Title" = "Łączenie z hostem";
"Help.Connecting.Body" = "Kliknij dwukrotnie połączenie w panelu bocznym, aby otworzyć je w nowej karcie. Sesje pozostają aktywne podczas przełączania kart — proces ssh/RDP nie jest uruchamiany ponownie. Kliknij prawym przyciskiem połączenie SSH, aby uzyskać dodatkowe opcje: transfer plików SFTP, narzędzia zewnętrzne, ponowne połączenie, wysłanie Ctrl+Alt+Del (dla RDP), kopiowanie hasła.";
"Help.Editing.Title" = "Edycja połączeń";
"Help.Editing.Body" = "Kliknij prawym przyciskiem połączenie > Edytuj..., lub zaznacz je i kliknij ikonę suwaków na pasku narzędzi. Edytor jest modalnym oknem w stylu Royal TSX z kategoriami po lewej stronie (Ogólne / Połączenie / Dane logowania / Wygląd / Zaawansowane) i formularzem po prawej. Kliknij Zastosuj, aby zapisać zmiany, lub Odrzuć, aby je cofnąć. Pasek stanu pod drzewem pokazuje hosta, użytkownika i hasło bieżącego elementu z możliwością kopiowania jednym kliknięciem.";
"Help.Shortcuts.Title" = "Skróty klawiaturowe";
"Help.Shortcuts.Body" = "Cmd+N — Nowa konfiguracja\nCmd+O — Otwórz konfigurację\nCmd+Shift+W — Zamknij konfigurację\nCmd+S — Zapisz\nCmd+= / Cmd+- — Zmień rozmiar tekstu terminala\nCmd+, — Ustawienia\nEnter — Edytuj wybrane połączenie\nDwuklik — Otwórz połączenie w nowej karcie";
"Help.Tips.Title" = "Wskazówki";
"Help.Tips.Body" = "• Przeciągaj połączenia i foldery, aby zmieniać ich kolejność. Upuść element na folder, aby go do niego przenieść.\n• Użyj pola wyszukiwania w panelu bocznym, aby filtrować według nazwy, hosta, protokołu lub opisu.\n• Panele (pasek kart u góry okna) grupują połączenia — ustaw atrybut Panel dla połączenia, aby umieścić je w innej grupie kart.\n• Zainstaluj sshpass przez Homebrew (brew install hudochenkov/sshpass/sshpass), aby umożliwić automatyczne wypełnianie haseł SSH. Bez niego SSH korzysta z klucza agenta lub interaktywnego logowania.\n• Każdy zapis tworzy kopię zapasową z datą i godziną w katalogu backups/ obok pliku confCons.xml — nie utracisz przypadkowo danych.";
"Help.Limitations.Title" = "Znane ograniczenia";
"Help.Limitations.Body" = "• FullFileEncryption=true (szyfrowanie całego XML) nie jest jeszcze obsługiwane.\n• Wersje schematu nowsze niż 2.6 nie były testowane.\n• Schowek obrazów RDP, przekierowanie dysków i dźwięku oraz widoczność zdalnego kursora nie są zaimplementowane.\n• Obsługa VNC oraz IntApp (uruchamianie aplikacji zewnętrznych) jest planowana, ale jeszcze niezaimplementowana.\n• Aplikacja jest podpisana ad-hoc — przy pierwszym uruchomieniu macOS wyświetli ostrzeżenie Gatekeepera. Uruchom: xattr -dr com.apple.quarantine /Applications/mRemoteNXT.app";
"Help.MoreInfo" = "Więcej informacji";
"Help.OpenIssue" = "Zgłoś błąd lub zaproponuj funkcję";
"Help.Email" = "Napisz do autora: razvan@cremenescu.ro";

